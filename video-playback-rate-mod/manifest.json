
{
  "manifest_version": 3,
  "name": "Playback Speed Controller",
  "version": "1.0",
  "description": "Control video playback speed on any page",
  "permissions": ["scripting", "activeTab", "storage"],
  "background": {
	"service_worker": "background.js"
  },
  "content_scripts": [
	{
	  "matches": ["<all_urls>"],
	  "js": ["content.js"],
	  "css": ["content.css"]
	}
  ],
  "action": {
	"default_popup": "popup/popup.html"
  }
}